<%- include('includes/nav') %>

  <!doctype html>
  <html lang="en">

  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AgendaPPP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  </head>

  <body>

    <div class="container">
      <div class="row">
        <div class="col-lg-2"></div>

        <div class="col-lg-8 my-5">
          <h1 class="text-center">Contato</h1>
          <p class="text-center lead">Seus contatos estão abaixo</p>

          <%- include('includes/messages') %>

            <div class="row">
              <div class="col-lg">
                <h4>Crie ou edite seu contato abaixo</h4>
                <form action="/contato/register" method="post">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                  <div class="mb-3">
                    <label>Nome</label>
                    <input value="<%= contato.nome %>" type="text" class="form-control" name="nome">
                  </div>
                  <div class="mb-3">
                    <label>Sobrenome</label>
                    <input type="text" class="form-control" name="sobrenome">
                  </div>
                  <div class="mb-3">
                    <label>email</label>
                    <input type="email" class="form-control" name="email">
                  </div>
                  <div class="mb-3">
                    <label>Telefone</label>
                    <input type="tel" class="form-control" name="telefone">
                  </div>

                  <button type="submit" class="btn btn-primary">Salvar</button>
                </form>
              </div>


            </div>
        </div>

        <div class="col-lg-2"></div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"></script>
  </body>

  </html>
  <%- include('includes/footer') %>